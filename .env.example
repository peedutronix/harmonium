# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Play Harmonium"
NEXT_PUBLIC_APP_DESCRIPTION = "Practice harmonium online with keyboard shortcuts, touch controls, and Sargam labels."
NEXT_PUBLIC_APP_LOGO = "/logo.png"
NEXT_PUBLIC_APP_FAVICON = "/favicon.ico"
NEXT_PUBLIC_APP_PREVIEW_IMAGE = "/preview.png"

# theme
NEXT_PUBLIC_THEME = "default"
NEXT_PUBLIC_APPEARANCE = "light"
NEXT_PUBLIC_DEFAULT_LOCALE = "en"

# database
DATABASE_PROVIDER = "postgresql"
DATABASE_URL = "postgresql://postgres:postgres@localhost:5432/harmonium"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth
AUTH_URL = "http://localhost:3000"
AUTH_SECRET = "replace-with-openssl-rand-base64-32"

# analytics and search console
GOOGLE_SITE_VERIFICATION = ""
GOOGLE_ANALYTICS_ID = ""
CLARITY_ID = ""
PLAUSIBLE_DOMAIN = ""
PLAUSIBLE_SRC = "https://plausible.io/js/script.js"
OPENPANEL_CLIENT_ID = ""
VERCEL_ANALYTICS_ENABLED = "false"
